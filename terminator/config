[global_config]
  window_state = maximise
  inactive_color_offset = 1.0
[keybindings]
  next_tab = <Shift><Alt>Right
  reset_clear = <Primary><Shift>l
  ungroup_all = <Primary><Alt>Right
  broadcast_off = <Primary><Alt>exclam
  broadcast_group = <Primary><Alt>1
[profiles]
  [[default]]
    font = JetBrainsMono Nerd Font 16
    foreground_color = "#ddb500"
    use_system_font = False
    title_transmit_fg_color = "#000000"
    title_transmit_bg_color = "#26a269"
    title_receive_bg_color = "#1c71d8"
    title_inactive_fg_color = "#ffffff"
    title_inactive_bg_color = "#000000"
[layouts]
  [[default]]
    [[[window0]]]
      type = Window
      parent = ""
    [[[child1]]]
      type = Terminal
      parent = window0
      profile = default
[plugins]
